Instance.OnScriptInput("tryPortalling", (context) => {
    // Instance.Msg("Trying portalling for " + context.activator?.GetEntityName() + " using " + context.caller?.GetEntityName());
    const activator = context.activator;
    const portal = context.caller;
    const isBlue = portal.GetEntityName().includes("blue");
    const name = portal.GetEntityName();
    const parts = name.split("_");
    const suffix = parts[parts.length - 1];
    // Instance.Msg(`Portal suffix = ${suffix}`);
    let secondPortal;
    if (isBlue) {
        secondPortal = Instance.FindEntityByName(`des_blue_portal_${suffix}`);
    }
    else {
        secondPortal = Instance.FindEntityByName(`des_orange_portal_${suffix}`);
    }
    teleportThroughPortal(activator, portal, secondPortal);
});

Instance.OnScriptInput("angleFix", (context) => {
    // Instance.Msg("Trying fix angle for " + context.activator?.GetEntityName());
    const activator = context.activator;
    const eyeAngles = activator.GetEyeAngles();
    // Instance.Msg("eyeAngles.pitch" + eyeAngles.pitch);
    // 1) Convert eye QAngle to forward vector
    const eyeDir = angleToVector(eyeAngles);
    eyeDir.z = -eyeDir.z;
    // 2) Re-derive a QAngle from that world vector
    const newEyeAngles = vectorToAngles(eyeDir);
    
    activator.Teleport({position: activator.GetAbsOrigin(), angles: newEyeAngles, velocity: activator.GetAbsVelocity()});
});